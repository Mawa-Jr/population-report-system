@startuml
skinparam actor {
  BorderColor DarkBlue
  BackgroundColor LightBlue
  FontSize 14
}
skinparam usecase {
  BorderColor Green
  BackgroundColor LightGreen
  FontSize 14
}
skinparam titleFontSize 24
skinparam noteBackgroundColor Yellow
skinparam noteBorderColor DarkRed

title USERCASE#4: View Capital Cities by Continent

actor "Data Analyst" as User
rectangle "Population Report System" {
  usecase "View Capital Cities by Continent" as UC4
}

User --> UC4 : Enter Continent

note right of UC4 : **Output:**\n- Capital City\n- Country Code\n- Population\n- (Ordered by population descending)

note left of UC4 : **Extensions:**\n- Invalid continent: Display error\n- Database failure: Display error\n- No capitals: Display "No capitals found"
@enduml
